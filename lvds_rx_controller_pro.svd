<?xml version="1.0" encoding="UTF-8"?>
<device schemaVersion="1.3" xmlns:xs="http://www.w3.org/2001/XMLSchema-instance" xs:noNamespaceSchemaLocation="CMSIS-SVD.xsd">
  <vendor>Mu3e</vendor>
  <vendorID>MU3E</vendorID>
  <name>MU3E_LVDS_RX_CONTROLLER_PRO</name>
  <series>MU3E_FPGA_IP</series>
  <version>26.2.1.0506</version>
  <description>CMSIS-SVD description of the current SystemVerilog mu3e_lvds_controller CSR window for N_LANE=9, N_ENGINE=1, ROUTING_TOPOLOGY=1, and AVMM_ADDR_W=10. This map matches mu3e_lvds_controller.sv version 26.2.1: UID/META at words 0/1, capability at word 2, global control words at 3..10, lane selector at word 16, and the selected-lane counter snapshot window at words 17..26. BaseAddress is 0 because this file describes the relative IP CSR aperture; system integration supplies the live SC-hub or JTAG base address.</description>
  <addressUnitBits>8</addressUnitBits>
  <width>32</width>
  <size>32</size>
  <access>read-write</access>
  <resetValue>0x00000000</resetValue>
  <resetMask>0xFFFFFFFF</resetMask>
  <peripherals>
    <peripheral>
      <name>LVDS_RX_CONTROLLER_PRO_CSR</name>
      <description>Relative CSR aperture for the current SystemVerilog LVDS receive controller.</description>
      <groupName>MU3E_LVDS_CONTROLLER</groupName>
      <baseAddress>0x0</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x1000</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>UID</name>
          <description>Software-visible LVDS controller UID. Default ASCII &quot;LVDS&quot; (0x4C564453).</description>
          <addressOffset>0x00</addressOffset>
          <access>read-only</access>
          <resetValue>0x4C564453</resetValue>
          <fields>
            <field>
              <name>value</name>
              <description>Compile-time or integration-time LVDS UID word.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>META</name>
          <description>Read-multiplexed metadata word. Write page[1:0] before reading back: 0=VERSION, 1=VERSION_DATE, 2=VERSION_GIT, 3=INSTANCE_ID.</description>
          <addressOffset>0x04</addressOffset>
          <access>read-write</access>
          <fields>
            <field>
              <name>page</name>
              <description>Selects the metadata read page.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>reserved</name>
              <description>Reserved, read as zero.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>30</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>CAPABILITY</name>
          <description>Packed capability word for the compiled lane/engine/routing profile.</description>
          <addressOffset>0x08</addressOffset>
          <access>read-only</access>
          <resetValue>0x1A01090A</resetValue>
          <fields>
            <field>
              <name>counter_count</name>
              <description>Number of per-lane counters exposed through the selected-lane counter window.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>n_lane</name>
              <description>Number of active LVDS lanes after RTL parameter clamping.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>n_engine</name>
              <description>Number of shared decode engines after RTL parameter clamping.</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>score_window_w</name>
              <description>Score-window width used by the engine steering score saturators.</description>
              <bitOffset>24</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>routing_topology</name>
              <description>Compiled routing topology selector.</description>
              <bitOffset>28</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SYNC_PATTERN</name>
          <description>Training/control symbol accepted as the lane synchronization pattern. Writes are accepted only for RTL-recognized K28.5/K28.0/K23.7 encodings.</description>
          <addressOffset>0x0C</addressOffset>
          <access>read-write</access>
          <resetValue>0x000000FA</resetValue>
          <fields>
            <field>
              <name>pattern</name>
              <description>10-bit synchronization symbol.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>10</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>reserved</name>
              <description>Reserved, read as zero.</description>
              <bitOffset>10</bitOffset>
              <bitWidth>22</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>LANE_GO</name>
          <description>Per-lane enable mask, clipped by the compiled active-lane mask.</description>
          <addressOffset>0x10</addressOffset>
          <access>read-write</access>
          <resetValue>0x000001FF</resetValue>
          <fields>
            <field>
              <name>lane_mask</name>
              <description>One bit per physical LVDS lane.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>DPA_HOLD</name>
          <description>Per-lane DPA hold request mask, clipped by the compiled active-lane mask.</description>
          <addressOffset>0x14</addressOffset>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>lane_mask</name>
              <description>One bit per physical LVDS lane.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SOFT_RESET</name>
          <description>Per-lane soft-reset request latch. Writing 1 requests a lane soft reset; RTL clears the bit after the hold interval completes.</description>
          <addressOffset>0x18</addressOffset>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>lane_mask</name>
              <description>One bit per physical LVDS lane.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>MODE_MASK</name>
          <description>Global two-bit lane mode in the current RTL. The full word is stored, but lane_mode() currently consumes bits [1:0].</description>
          <addressOffset>0x1C</addressOffset>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>mode</name>
              <description>0=bitslipping, 1=adapting, 2=autoing.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>reserved_storage</name>
              <description>Stored by RTL for future per-lane mode expansion; currently not decoded by lane_mode().</description>
              <bitOffset>2</bitOffset>
              <bitWidth>30</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SCORE_ACCEPT</name>
          <description>Engine steering accept threshold, clamped by the RTL score window.</description>
          <addressOffset>0x20</addressOffset>
          <access>read-write</access>
          <resetValue>0x00000008</resetValue>
          <fields>
            <field>
              <name>threshold</name>
              <description>Accept threshold.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>reserved</name>
              <description>Reserved, read as zero.</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SCORE_REJECT</name>
          <description>Engine steering reject threshold, clamped not to exceed SCORE_ACCEPT.</description>
          <addressOffset>0x24</addressOffset>
          <access>read-write</access>
          <resetValue>0x00000002</resetValue>
          <fields>
            <field>
              <name>threshold</name>
              <description>Reject threshold.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>reserved</name>
              <description>Reserved, read as zero.</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>STEER_STATUS</name>
          <description>Snapshot status from the data-clock steering queue. This read may wait while the control clock requests the data-clock snapshot.</description>
          <addressOffset>0x28</addressOffset>
          <access>read-only</access>
          <fields>
            <field>
              <name>steer_queue_count</name>
              <description>Current queued engine-steering decisions.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>reserved</name>
              <description>Reserved, read as zero.</description>
              <bitOffset>6</bitOffset>
              <bitWidth>10</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>steer_overflow_count_low</name>
              <description>Low 16 bits of the saturating steering-queue overflow counter.</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>LANE_SELECT</name>
          <description>Selected lane for the counter snapshot window. Writes above the last active lane clamp to the last active lane.</description>
          <addressOffset>0x40</addressOffset>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>lane</name>
              <description>Zero-based lane index for counter snapshot reads.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>reserved</name>
              <description>Reserved, read as zero.</description>
              <bitOffset>6</bitOffset>
              <bitWidth>26</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>CODE_VIOLATIONS</name>
          <description>Illegal or unexpected 8b/10b symbol events observed on the selected lane. The lane is selected by LANE_SELECT and the value is returned through the RTL snapshot path.</description>
          <addressOffset>0x44</addressOffset>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>value</name>
              <description>Selected-lane saturating counter value.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>DISP_VIOLATIONS</name>
          <description>Disparity violation events observed on the selected lane. The lane is selected by LANE_SELECT and the value is returned through the RTL snapshot path.</description>
          <addressOffset>0x48</addressOffset>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>value</name>
              <description>Selected-lane saturating counter value.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>COMMA_LOSSES</name>
          <description>Selected-lane comma/sync-pattern loss events. The lane is selected by LANE_SELECT and the value is returned through the RTL snapshot path.</description>
          <addressOffset>0x4C</addressOffset>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>value</name>
              <description>Selected-lane saturating counter value.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>BITSLIP_EVENTS</name>
          <description>Selected-lane bitslip control events. The lane is selected by LANE_SELECT and the value is returned through the RTL snapshot path.</description>
          <addressOffset>0x50</addressOffset>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>value</name>
              <description>Selected-lane saturating counter value.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>DPA_UNLOCKS</name>
          <description>Selected-lane DPA unlock events. The lane is selected by LANE_SELECT and the value is returned through the RTL snapshot path.</description>
          <addressOffset>0x54</addressOffset>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>value</name>
              <description>Selected-lane saturating counter value.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>REALIGNS</name>
          <description>Selected-lane realignment events. The lane is selected by LANE_SELECT and the value is returned through the RTL snapshot path.</description>
          <addressOffset>0x58</addressOffset>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>value</name>
              <description>Selected-lane saturating counter value.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SCORE_CHANGES</name>
          <description>Selected-lane engine-score change events. The lane is selected by LANE_SELECT and the value is returned through the RTL snapshot path.</description>
          <addressOffset>0x5C</addressOffset>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>value</name>
              <description>Selected-lane saturating counter value.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>ENGINE_STEER</name>
          <description>Selected-lane engine steering decisions. The lane is selected by LANE_SELECT and the value is returned through the RTL snapshot path.</description>
          <addressOffset>0x60</addressOffset>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>value</name>
              <description>Selected-lane saturating counter value.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SOFT_RESETS</name>
          <description>Selected-lane soft-reset completions. The lane is selected by LANE_SELECT and the value is returned through the RTL snapshot path.</description>
          <addressOffset>0x64</addressOffset>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>value</name>
              <description>Selected-lane saturating counter value.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>UPTIME</name>
          <description>Selected-lane uptime counter in data-clock cycles. The lane is selected by LANE_SELECT and the value is returned through the RTL snapshot path.</description>
          <addressOffset>0x68</addressOffset>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>value</name>
              <description>Selected-lane saturating counter value.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
  </peripherals>
</device>
