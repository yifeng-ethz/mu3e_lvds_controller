            desc.pass_criteria = "Engine reports `accept` on first match; never `reject` between accept events while `score_reject=0`.";
            desc.expect_sva_failure = 0;
        end
        "E006": begin
            desc.id = "E006";
            desc.bucket = LVDS_BUCKET_EDGE;
