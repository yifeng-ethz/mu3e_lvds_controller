            desc.scenario = "`sva_counter_sat` liveness";
            desc.stimulus = "Use debug hook to write a counter at `0xFFFFFFFE` and inject a 2-event burst.";
            desc.pass_criteria = "Counter saturates at `0xFFFFFFFF`; no wrap and no SVA failure.";
            desc.expect_sva_failure = 0;
        end
        "X037": begin
            desc.id = "X037";
            desc.bucket = LVDS_BUCKET_ERROR;
            desc.method = LVDS_METHOD_DIRECTED;
            desc.group = lvds_group_from_id("X037");
            desc.case_num = 37;
            desc.iterations = 1;
            desc.scenario = "`sva_avalon_st` liveness";
            desc.stimulus = "Hold `ready=0` while the DUT presents decoded output.";
            desc.pass_criteria = "Payload remains stable while stalled; no SVA failure.";
            desc.expect_sva_failure = 0;
        end
        "X038": begin
            desc.id = "X038";
            desc.bucket = LVDS_BUCKET_ERROR;
            desc.method = LVDS_METHOD_DIRECTED;
            desc.group = lvds_group_from_id("X038");
            desc.case_num = 38;
            desc.iterations = 1;
            desc.scenario = "`sva_avalon_mm` liveness";
            desc.stimulus = "Exercise CSR read/write timing and DV-only invalid debug pulses in the same case.";
            desc.pass_criteria = "Avalon-MM stability checks stay quiet; invalid debug pulses are ignored.";
            desc.expect_sva_failure = 0;
        end
        "X039": begin
            desc.id = "X039";
            desc.bucket = LVDS_BUCKET_ERROR;
            desc.method = LVDS_METHOD_DIRECTED;
            desc.group = lvds_group_from_id("X039");
            desc.case_num = 39;
            desc.iterations = 1;
            desc.scenario = "`sva_csr_aperture` liveness";
            desc.stimulus = "Read the counter aperture and sweep debug-only engine score/age preload guards.";
            desc.pass_criteria = "CSR aperture remains stable; debug guard paths toggle for coverage; no SVA failure.";
            desc.expect_sva_failure = 0;
        end
        "X040": begin
            desc.id = "X040";
            desc.bucket = LVDS_BUCKET_ERROR;
            desc.method = LVDS_METHOD_DIRECTED;
            desc.group = lvds_group_from_id("X040");
            desc.case_num = 40;
            desc.iterations = 1;
            desc.scenario = "`sva_engine_attach` liveness";
            desc.stimulus = "Attach an engine through the debug hook and then drive a normal release window.";
            desc.pass_criteria = "Engine attach accounting remains bounded and legal; no SVA failure.";
            desc.expect_sva_failure = 0;
        end
        "X041": begin
            desc.id = "X041";
            desc.bucket = LVDS_BUCKET_ERROR;
            desc.method = LVDS_METHOD_DIRECTED;
            desc.group = lvds_group_from_id("X041");
            desc.case_num = 41;
            desc.iterations = 1;
            desc.scenario = "`sva_train_fsm` liveness";
            desc.stimulus = "Exercise reset and training transitions around the debug-hook probe window.";
            desc.pass_criteria = "Training FSM remains in a legal state across the probe; no SVA failure.";
            desc.expect_sva_failure = 0;
        end
        "X042": begin
            desc.id = "X042";
            desc.bucket = LVDS_BUCKET_ERROR;
            desc.method = LVDS_METHOD_DIRECTED;
            desc.group = lvds_group_from_id("X042");
            desc.case_num = 42;
            desc.iterations = 1;
            desc.scenario = "Both resets asserted then released same cycle";
            desc.stimulus = "Assert both, hold 16 cycles, deassert both same cycle.";
            desc.pass_criteria = "DUT walks normal init; CSR responsive after `control_reset_release_latency`; data path follows section B021-section B024.";
            desc.expect_sva_failure = 0;
        end
        "X043": begin
            desc.id = "X043";
            desc.bucket = LVDS_BUCKET_ERROR;
            desc.method = LVDS_METHOD_DIRECTED;
            desc.group = lvds_group_from_id("X043");
            desc.case_num = 43;
            desc.iterations = 1;
            desc.scenario = "Control reset deassert before data reset";
            desc.stimulus = "Deassert `rsi_control_reset` first; hold `rsi_data_reset` for 100 more cycles.";
            desc.pass_criteria = "CSR responsive; data path stays held; init begins when `rsi_data_reset` deasserts.";
            desc.expect_sva_failure = 0;
        end
        "X044": begin
            desc.id = "X044";
            desc.bucket = LVDS_BUCKET_ERROR;
            desc.method = LVDS_METHOD_DIRECTED;
            desc.group = lvds_group_from_id("X044");
            desc.case_num = 44;
            desc.iterations = 1;
            desc.scenario = "Data reset deassert before control reset";
            desc.stimulus = "Deassert `rsi_data_reset` first; hold `rsi_control_reset` for 100 more cycles.";
            desc.pass_criteria = "Data path inits; CSR unreachable until control reset deasserts. The training FSM still completes for any lane that gets a valid PHY conduit.";
            desc.expect_sva_failure = 0;
        end
        "X045": begin
            desc.id = "X045";
            desc.bucket = LVDS_BUCKET_ERROR;
            desc.method = LVDS_METHOD_DIRECTED;
            desc.group = lvds_group_from_id("X045");
            desc.case_num = 45;
            desc.iterations = 1;
            desc.scenario = "Reset asserted during CSR write";
            desc.stimulus = "Issue CSR write; assert `rsi_control_reset` mid-cycle.";
            desc.pass_criteria = "Write may be lost; no `waitrequest` deadlock after reset releases; harness re-reads to confirm.";
            desc.expect_sva_failure = 0;
        end
        "X046": begin
            desc.id = "X046";
            desc.bucket = LVDS_BUCKET_ERROR;
            desc.method = LVDS_METHOD_DIRECTED;
            desc.group = lvds_group_from_id("X046");
            desc.case_num = 46;
            desc.iterations = 1;
            desc.scenario = "Reset asserted during AVST handshake";
            desc.stimulus = "While `aso_decoded[0]` is mid-beat (`valid=1, ready=0`), assert `rsi_data_reset`.";
            desc.pass_criteria = "DUT drops the beat cleanly; `valid=0` next cycle; no SVA violation on AVST contract during reset (the `valid_during_reset = 0` rule must hold).";
            desc.expect_sva_failure = 0;
        end
        "X047": begin
            desc.id = "X047";
            desc.bucket = LVDS_BUCKET_ERROR;
            desc.method = LVDS_METHOD_DIRECTED;
            desc.group = lvds_group_from_id("X047");
            desc.case_num = 47;
            desc.iterations = 1;
            desc.scenario = "Reset asserted during engine attach";
            desc.stimulus = "Engine attaching lane 0; assert `rsi_data_reset` 1 cycle after the attach event.";
            desc.pass_criteria = "Engine cleanly detaches; `engine_busy_mask=0` after reset.";
            desc.expect_sva_failure = 0;
        end
        "X048": begin
            desc.id = "X048";
            desc.bucket = LVDS_BUCKET_ERROR;
            desc.method = LVDS_METHOD_DIRECTED;
            desc.group = lvds_group_from_id("X048");
            desc.case_num = 48;
            desc.iterations = 1;
            desc.scenario = "Reset asserted during bitslip walk";
            desc.stimulus = "Lane 0 mid-walk; assert `rsi_data_reset`.";
            desc.pass_criteria = "Walk aborts; lane 0 returns to phase 0 after reset release.";
            desc.expect_sva_failure = 0;
        end
        "X049": begin
            desc.id = "X049";
            desc.bucket = LVDS_BUCKET_ERROR;
            desc.method = LVDS_METHOD_DIRECTED;
            desc.group = lvds_group_from_id("X049");
            desc.case_num = 49;
            desc.iterations = 1;
            desc.scenario = "Reset asserted during DPA training";
            desc.stimulus = "Lane 0 in DPA-training; assert `rsi_data_reset`.";
            desc.pass_criteria = "DPA training restarts cleanly per section B021.";
            desc.expect_sva_failure = 0;
        end
        "X050": begin
            desc.id = "X050";
            desc.bucket = LVDS_BUCKET_ERROR;
            desc.method = LVDS_METHOD_DIRECTED;
            desc.group = lvds_group_from_id("X050");
            desc.case_num = 50;
            desc.iterations = 1;
            desc.scenario = "Reset glitch (1-cycle pulse)";
            desc.stimulus = "Pulse `rsi_data_reset=1` for 1 cycle.";
            desc.pass_criteria = "DUT either treats it as a real reset (entering full init) or filters it (codex must commit and document; the plan accepts either provided `sva_*` properties continue to hold).";
            desc.expect_sva_failure = 0;
        end
        default: begin end
    endcase
    return desc;
endfunction

function automatic int lvds_case_count();
    return 218;
endfunction

