function automatic int lvds_bucket_case_count(input lvds_bucket_e bucket);
    unique case (bucket)
        LVDS_BUCKET_BASIC: return 78;
        LVDS_BUCKET_EDGE: return 50;
        LVDS_BUCKET_PROF: return 40;
        LVDS_BUCKET_ERROR: return 50;
        default: return 0;
    endcase
endfunction

