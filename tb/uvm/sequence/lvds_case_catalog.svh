            desc.case_num = 6;
            desc.iterations = 1;
            desc.scenario = "Score tie between two phases";
            desc.stimulus = "Inject a stream where phases 3 and 7 score the same window.";
            desc.pass_criteria = "DUT picks phase 3 (lowest index); `engine_best_phase=3`; `realigns` does not increment when the tie clears in favour of phase 3.";
            desc.expect_sva_failure = 0;
        end
