            desc.pass_criteria = "DUT detaches the engine, lane 0 falls back to mini-decoder bitslip walk; `engine_steerings[0]` may have incremented twice (initial + retry); `realigns[0]` increments on the new phase pick.";
            desc.expect_sva_failure = 0;
