            desc.pass_criteria = "Engine attaches lane 3 first (lowest index); lane 7 enqueued; `steer_queue_count=1` peak; engine releases lane 3 then attaches lane 7; `engine_steerings = [.,.,.,1,.,.,.,1,...]`.";
